# VegaPal — copy to .env.local (development) or set in Vercel (production).
# Never commit real keys. .env.local and .env.production are gitignored.

# --- Supabase (required) ---
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=
SUPABASE_URL=

# Publishable (anon) key — safe for browser; also used server-side for user JWT validation
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Service role key — server only (admin API, bypasses RLS). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare Turnstile (optional locally; required on production vega-pal.com) ---
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
